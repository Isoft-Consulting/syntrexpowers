  "variant_rules": {
    "permission-request mirror fields": {
      "selectors": [
        "logical_event=permission-request"
      ],
      "requires": [
        "permission object populated",
        "requested_tool_kind mirrored"
      ],
      "forbids": [
        "missing permission tuple"
      ]
    },
    "current-turn assistant text byte and truncation coupling": {
      "selectors": [
        "logical_event=stop or subagent-stop"
      ],
      "requires": [
        "assistant text bytes",
        "assistant_text_truncated flag"
      ],
      "forbids": [
        "truncated flag without byte cap"
      ]
    },
    "unknown sentinel fail-closed fields": {
      "selectors": [
        "provider=unknown or logical_event=unknown"
      ],
      "requires": [
        "raw_event captured",
        "fail-closed sentinel fields"
      ],
      "forbids": [
        "allow decision derived from unknown"
      ]
    }
