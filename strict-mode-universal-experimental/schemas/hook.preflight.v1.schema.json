      "user-prompt-submit",
      "pre-tool-use",
      "post-tool-use",
      "stop",
      "subagent-stop",
      "permission-request",
      "unknown"
    ],
    "decision": [
      "allow",
      "block",
      "unknown"
    ],
    "reason_code": [
      "not-applicable",
      "payload-untrusted",
      "provider-untrusted",
      "payload-truncated",
      "protected-baseline-untrusted",
      "preflight-error",
      "shell-read-only-or-unmatched",
      "non-write-tool",
      "write-targets-disjoint",
      "trusted-import-ready",
      "destructive-confirmed",
      "invalid-identity",
      "shell-command-missing",
      "shell-parse-error",
      "protected-runtime-execution",
      "destructive-command",
      "protected-root",
      "unknown-write-target",
      "protected-target-unknown",
      "trusted-import-invalid",
      "trusted-import-unavailable",
      "stub-detected"
    ],
    "tool_kind": [
      "shell",
      "write",
      "edit",
      "multi-edit",
      "patch",
      "read",
      "other",
      "unknown"
    ],
    "tool_write_intent": [
      "none",
      "read",
      "write",
      "unknown"
    ]
  },
  "variant_requirements": [
    "not-attempted sentinel fields",
    "untrusted diagnostic sentinel fields",
    "trusted classifier decision coupling"
  ],
  "variant_rules": {
    "not-attempted sentinel fields": {
      "selectors": [
        "attempted=false"
      ],
      "requires": [
        "trusted=false",
        "decision=unknown",
        "would_block=false",
        "reason_code=not-applicable",
        "data hashes zero",
        "error_count=0"
      ],
      "forbids": [
        "trusted=true",
        "nonzero data hash"
      ]
    },
    "untrusted diagnostic sentinel fields": {
      "selectors": [
        "attempted=true",
        "trusted=false"
      ],
      "requires": [
        "decision=unknown",
        "would_block=false",
        "untrusted reason_code",
        "positive error_count",
        "nonzero error_hash",
        "tool hashes zero"
      ],
      "forbids": [
        "decision=allow or block",
        "would_block=true",
        "raw diagnostic text"
      ]
    },
    "trusted classifier decision coupling": {
      "selectors": [
        "attempted=true",
        "trusted=true"
      ],
      "requires": [
        "decision allow or block",
        "would_block equals block decision",
        "classifier reason_code matches decision",
        "error_hash zero"
      ],
      "forbids": [
        "unknown decision",
        "mismatched allow/block reason_code",
        "diagnostic errors populated"
      ]
    }
  },
