#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"

command = ARGV.shift
separator = ARGV.shift
path = ARGV.shift

unless command == "import" && separator == "--" && path && ARGV.empty?
  warn "usage: strict-fdr import -- <artifact-path>"
  exit 2
end

unless File.file?(path)
  warn "#{path}: artifact is not a file"
  exit 1
end

puts JSON.pretty_generate({
  "schema_version" => 1,
  "mode" => "discovery-import-unavailable",
  "source_path" => File.expand_path(path),
  "decision" => "block",
  "reason_code" => "trusted-import-unavailable",
  "reason" => "strict-fdr import requires the artifact importer before it can create trusted state"
})
exit 1
