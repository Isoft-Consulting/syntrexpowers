  ],
  "variant_rules": {
    "enforcing hook entry output contract required": {
      "selectors": [
        "hook enforcing=true"
      ],
      "requires": [
        "fixture_manifest_records decision-output"
      ],
      "forbids": [
        "missing output contract"
      ]
    },
    "discovery entry output contract empty allowed": {
      "selectors": [
        "hook enforcing=false"
      ],
      "requires": [
        "empty output contract allowed"
      ],
      "forbids": [
        "required deny output"
      ]
    },
    "lexical active strict-hook command binding": {
      "selectors": [
        "managed hook entry"
      ],
      "requires": [
        "STRICT_HOOK_TIMEOUT_MS=<ms> STRICT_STATE_ROOT=\"<state-root>\" \"<install-root>/active/bin/strict-hook\" --provider <provider> <logical_event>",
        "timeout/state-root/provider/event parity"
      ],
      "forbids": [
        "release realpath",
        "outside install root",
        "shell wrapper",
        "extra argv",
        "provider drift"
      ]
    }
  },
