  "field_details": {
    "data hash fields": {
      "shape": "hash-group",
      "members": [
        "reason_hash",
        "tool_name_hash",
        "command_hash",
        "path_list_hash",
        "error_hash",
        "preflight_hash"
      ],
      "rules": [
        "lowercase SHA-256",
        "preflight_hash recomputed",
        "raw values not retained"
      ]
    },
    "tool summary fields": {
      "shape": "object-fields",
      "members": [
        "tool_kind",
        "tool_write_intent",
        "tool_name_hash",
        "command_hash",
        "path_list_hash"
      ],
      "rules": [
        "hashed command, path list, and tool name only"
      ]
    },
    "error diagnostic fields": {
      "shape": "object-fields",
      "members": [
        "error_count",
        "error_hash"
      ],
      "rules": [
        "untrusted diagnostics hashed only"
      ]
    }
  },
  "enum_families": [
    "logical_event",
    "decision",
    "reason_code",
    "tool_kind",
    "tool_write_intent"
  ],
