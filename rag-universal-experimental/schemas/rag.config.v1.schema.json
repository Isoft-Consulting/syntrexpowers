{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rag.config.v1",
  "type": "object",
  "required": ["schema_version", "index_dir", "include_globs", "exclude_dirs", "secret_path_patterns"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "const": "rag.config.v1" },
    "index_dir": { "type": "string" },
    "include_globs": { "type": "array", "items": { "type": "string" } },
    "force_include_globs": { "type": "array", "items": { "type": "string" } },
    "exclude_dirs": { "type": "array", "items": { "type": "string" } },
    "exclude_globs": { "type": "array", "items": { "type": "string" } },
    "secret_path_patterns": { "type": "array", "items": { "type": "string" } },
    "max_file_bytes": { "type": "integer", "minimum": 1 },
    "follow_symlinks": { "type": "boolean" },
    "chunk": {
      "type": "object",
      "properties": {
        "max_chars": { "type": "integer", "minimum": 1 },
        "min_chars": { "type": "integer", "minimum": 0 },
        "overlap_chars": { "type": "integer", "minimum": 0 }
      }
    },
    "search": {
      "type": "object",
      "properties": {
        "hash_dim": { "type": "integer", "minimum": 16 },
        "min_score": { "type": "number", "minimum": 0 },
        "docs_boost": { "type": "number", "minimum": 0 },
        "matrix_boost": { "type": "number", "minimum": 0 },
        "schema_boost": { "type": "number", "minimum": 0 },
        "test_boost": { "type": "number", "minimum": 0 },
        "code_boost": { "type": "number", "minimum": 0 },
        "vector_weight": { "type": "number", "minimum": 0 },
        "bm25_weight": { "type": "number", "minimum": 0 },
        "source_weight": { "type": "number", "minimum": 0 },
        "heading_weight": { "type": "number", "minimum": 0 },
        "max_chunks_per_source": { "type": "integer", "minimum": 1 },
        "candidate_limit": { "type": "integer", "minimum": 1 },
        "explicit_path_boost": { "type": "number", "minimum": 0 },
        "source_penalties": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["pattern", "multiplier"],
            "properties": {
              "pattern": { "type": "string" },
              "multiplier": { "type": "number", "minimum": 0, "maximum": 1 }
            },
            "additionalProperties": false
          }
        },
        "fdr_role_boosts": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 }
        },
        "fdr_query_expansions": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "expand_english_synonyms": { "type": "boolean" },
        "preview_chars": { "type": "integer", "minimum": 1 },
        "synonyms": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
