    "permission.network": {
      "shape": "object",
      "members": [
        "scheme",
        "host",
        "port",
        "operation"
      ],
      "rules": [
        "canonical host and port domain"
      ]
    },
    "prompt": {
      "shape": "object",
      "members": [
        "prompt text hash",
        "prompt byte counts"
      ],
      "rules": [
        "raw prompt privacy bounds"
      ]
    },
    "assistant": {
      "shape": "object",
      "members": [
        "current turn text",
        "byte count",
        "truncated flag"
      ],
      "rules": [
        "truncation flag coupled to byte cap"
      ]
    },
    "raw": {
      "shape": "object",
