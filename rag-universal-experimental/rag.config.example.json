{
  "schema_version": "rag.config.v1",
  "index_dir": ".rag-index",
  "include_globs": [
    "**/*.md",
    "**/*.txt",
    "**/*.json",
    "**/*.yaml",
    "**/*.yml",
    "**/*.rb",
    "**/*.py",
    "**/*.js",
    "**/*.ts",
    "**/*.sh",
    "**/*.php"
  ],
  "exclude_dirs": [
    ".git",
    ".mcp",
    ".claude",
    ".codex",
    ".agents",
    ".rag-index",
    "node_modules",
    "vendor",
    "dist",
    "build",
    "coverage",
    "__pycache__",
    ".pytest_cache",
    ".ruff_cache"
  ],
  "exclude_globs": [
    "**/*.lock",
    "**/*.map",
    "**/*.min.js",
    "**/*.min.css"
  ],
  "secret_path_patterns": [
    "**/.env",
    "**/.env.*",
    "**/.mcp.json",
    "**/*secret*",
    "**/*credential*",
    "**/*token*",
    "**/*.pem",
    "**/*.key",
    "**/*.p12",
    "**/*.crt",
    "**/id_rsa",
    "**/id_ed25519"
  ],
  "max_file_bytes": 1048576,
  "follow_symlinks": false,
  "chunk": {
    "max_chars": 2400,
    "min_chars": 160,
    "overlap_chars": 160
  },
  "search": {
    "hash_dim": 512,
    "min_score": 0.02,
    "docs_boost": 1.08,
    "preview_chars": 500
  }
}
