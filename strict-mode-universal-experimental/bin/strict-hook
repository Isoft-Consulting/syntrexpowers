#!/usr/bin/env ruby
# frozen_string_literal: true

require "digest"
require "fileutils"
require "json"
require "open3"
require "optparse"
require "pathname"
require "rbconfig"
require "securerandom"
require "time"
require_relative "../tools/decision_contract_lib"
require_relative "../tools/approval_state_lib"
require_relative "../tools/destructive_gate_lib"
require_relative "../tools/fdr_cycle_lib"
require_relative "../tools/fdr_import_lib"
require_relative "../tools/fixture_readiness_lib"
require_relative "../tools/internal_decision_lib"
require_relative "../tools/normalized_event_lib"
require_relative "../tools/permission_decision_lib"
require_relative "../tools/preflight_record_lib"
require_relative "../tools/protected_baseline_lib"
require_relative "../tools/provider_detection_lib"
require_relative "../tools/record_edit_lib"

options = { "provider" => nil }
parser = OptionParser.new do |opts|
  opts.on("--provider PROVIDER") { |value| options["provider"] = value }
end

begin
  parser.order!(ARGV)
rescue OptionParser::ParseError => e
  warn "strict-hook usage error: #{e.message}"
  exit 2
end

event = ARGV.shift || "unknown"
provider_arg_source = if options["provider"]
                        "argv"
                      elsif ENV["STRICT_PROVIDER"]
                        "env"
                      else
                        "unknown"
                      end
provider = options["provider"] || ENV["STRICT_PROVIDER"] || "unknown"
unless %w[claude codex unknown].include?(provider)
  warn "strict-hook provider mismatch: unsupported provider #{provider.inspect}"
  provider = "unknown"
  provider_arg_source = "unknown"
end

def safe_component(value)
  raw = value.to_s
  component = raw.downcase
  raw.match?(/\A[A-Za-z0-9][A-Za-z0-9._-]*\z/) && component.match?(/\A[a-z0-9][a-z0-9._-]*\z/) ? component : "unknown"
end

def prompt_injection_session_key(provider, parsed_payload)
  return "" unless parsed_payload.is_a?(Hash)

  stable_id = %w[session_id conversation_id transcript_path].map { |key| parsed_payload[key].to_s }.find { |value| !value.empty? }
  return "" unless stable_id

  Digest::SHA256.hexdigest("#{provider}:#{stable_id}")
end

def should_emit_prompt_injection?(state_root, provider, parsed_payload)
  key = prompt_injection_session_key(provider, parsed_payload)
  return true if key.empty?

  marker_dir = state_root.join("prompt-injection")
  marker_path = marker_dir.join("#{key}.seen")
  FileUtils.mkdir_p(marker_dir, mode: 0o700)
  File.open(marker_path, File::WRONLY | File::CREAT | File::EXCL, 0o600) do |file|
    file.puts(Time.now.utc.iso8601)
  end
  true
rescue Errno::EEXIST
  false
rescue SystemCallError, RuntimeError => e
  warn "strict-hook prompt injection marker failed: #{e.message}"
  true
end

def canonical_path(value)
  path = Pathname.new(value.to_s).expand_path
  path.exist? ? path.realpath : path.cleanpath
rescue ArgumentError, Errno::ENOENT, SystemCallError
  Pathname.new(value.to_s).expand_path.cleanpath
end

def inferred_install_root(state_root = nil)
  return Pathname.new(ENV["STRICT_INSTALL_ROOT"]).expand_path.cleanpath if ENV["STRICT_INSTALL_ROOT"]

  program = Pathname.new($PROGRAM_NAME).expand_path.cleanpath
  if program.basename.to_s == "strict-hook" &&
     program.dirname.basename.to_s == "bin" &&
     program.dirname.dirname.basename.to_s == "active"
    return program.dirname.dirname.dirname
  end

  return state_root.dirname if state_root

  Pathname.new(File.join(Dir.home, ".strict-mode"))
end

def hook_cwd
  canonical_path(ENV["STRICT_CWD"] || Dir.pwd)
end

def hook_project_dir(cwd)
  canonical_path(ENV["STRICT_PROJECT_DIR"] || cwd.to_s)
end

def preflight_not_attempted(logical_event)
  StrictModePreflightRecord.not_attempted(logical_event)
end

def preflight_error(logical_event, reason_code, errors)
  StrictModePreflightRecord.untrusted(logical_event, reason_code, errors)
end

def validate_preflight_or_error(logical_event, preflight)
  errors = StrictModePreflightRecord.validate(preflight)
  return preflight if errors.empty?

  warn "strict-hook preflight contract invalid: #{errors.length} validation errors (discovery log-only)"
  preflight_error(logical_event, "preflight-error", errors)
end

def classify_preflight(payload:, provider:, logical_event:, payload_hash:, state_root:)
  return preflight_not_attempted(logical_event) unless logical_event == "pre-tool-use"
  return preflight_error(logical_event, "payload-untrusted", ["payload JSON root is not an object"]) unless payload.is_a?(Hash)

  cwd = hook_cwd
  project_dir = hook_project_dir(cwd)
  install_root = inferred_install_root(state_root)
  event = StrictModeNormalized.normalize(
    payload,
    provider: provider,
    logical_event: logical_event,
    cwd: cwd,
    project_dir: project_dir,
    payload_sha256: payload_hash
  )
  baseline = StrictModeProtectedBaseline.load(
    install_root: install_root,
    state_root: state_root,
    project_dir: project_dir,
    home: Dir.home
  )
  unless baseline.fetch("trusted")
    return preflight_error(
      logical_event,
      "protected-baseline-untrusted",
      baseline.fetch("errors") + baseline.fetch("config_errors")
    )
  end

  raw_tool_input = payload.is_a?(Hash) ? payload["tool_input"] : nil
  decision = StrictModeDestructiveGate.classify_tool(
    event.fetch("tool"),
    cwd: event.fetch("cwd"),
    project_dir: event.fetch("project_dir"),
    protected_roots: baseline.fetch("protected_roots"),
    protected_inodes: baseline.fetch("protected_inodes"),
    destructive_patterns: baseline.fetch("destructive_patterns"),
    stub_allowlist: baseline.fetch("stub_allowlist"),
    raw_tool_input: raw_tool_input,
    home: baseline.fetch("home"),
    install_root: baseline.fetch("install_root")
  )
  tool = event.fetch("tool")
  StrictModePreflightRecord.trusted_from_classifier(logical_event, decision, tool)
rescue RuntimeError, SystemCallError, ArgumentError => e
  preflight_error(logical_event, "preflight-error", [e.message])
end

def protected_runtime_settings(state_root)
  cwd = hook_cwd
  loaded = StrictModeProtectedBaseline.load(
    install_root: inferred_install_root(state_root),
    state_root: state_root,
    project_dir: hook_project_dir(cwd),
    home: Dir.home
  )
  unless loaded.fetch("trusted")
    warn "strict-hook protected runtime config unavailable: #{(loaded.fetch("errors") + loaded.fetch("config_errors")).join("; ")}"
    return {}
  end

  runtime = loaded.fetch("config_results").fetch("runtime.env", { "records" => [] })
  runtime.fetch("records").each_with_object({}) do |record, settings|
    settings[record.fetch("key")] = record.fetch("value")
  end
rescue RuntimeError, SystemCallError, ArgumentError, KeyError => e
  warn "strict-hook protected runtime config unavailable: #{e.message}"
  {}
end

def protected_context(state_root)
  cwd = hook_cwd
  StrictModeProtectedBaseline.load(
    install_root: inferred_install_root(state_root),
    state_root: state_root,
    project_dir: hook_project_dir(cwd),
    home: Dir.home
  )
rescue RuntimeError, SystemCallError, ArgumentError => e
  StrictModeProtectedBaseline.result(false, [e.message], [])
end

def enforcing_hook_entry_from(record, provider, logical_event)
  return nil unless record.is_a?(Hash)

  Array(record["managed_hook_entries"]).find do |entry|
    entry.is_a?(Hash) &&
      entry["provider"] == provider &&
      entry["logical_event"] == logical_event &&
      entry["enforcing"] == true &&
      entry["output_contract_id"].is_a?(String) &&
      !entry["output_contract_id"].empty?
  end
end

def selected_output_contract_id_from(record, provider, logical_event)
  return "" unless record.is_a?(Hash)

  contract = Array(record["selected_output_contracts"]).find do |entry|
    entry.is_a?(Hash) &&
      entry["provider"] == provider &&
      entry["logical_event"] == logical_event &&
      entry["contract_kind"] == "decision-output" &&
      entry["contract_id"].is_a?(String) &&
      !entry["contract_id"].empty?
  end
  contract ? contract.fetch("contract_id") : ""
end

def fallback_enforcing_hook_entry(context, provider, logical_event)
  return nil unless blocking_capable_logical_event?(logical_event)

  [context.fetch("manifest", {}), context.fetch("baseline", {})].each do |record|
    contract_id = selected_output_contract_id_from(record, provider, logical_event)
    next if contract_id.empty?

    return {
      "provider" => provider,
      "logical_event" => logical_event,
      "output_contract_id" => contract_id,
      "enforcing" => true
    }
  end
  nil
end

def enforcing_hook_entry(context, provider, logical_event)
  entry = enforcing_hook_entry_from(context.fetch("baseline", {}), provider, logical_event)
  return entry if entry

  entry = enforcing_hook_entry_from(context.fetch("manifest", {}), provider, logical_event)
  return entry if entry

  fallback_enforcing_hook_entry(context, provider, logical_event)
end

def blocking_capable_logical_event?(logical_event)
  StrictModeFixtureReadiness::BLOCKING_EVENTS.include?(logical_event)
end

def stop_continuation_logical_event?(logical_event)
  StrictModeInternalDecision::STOP_LIKE_EVENTS.include?(logical_event)
end

def enforcing_hook_invocation?
  ENV["STRICT_ENFORCING_HOOK"] == "1"
end

def fallback_output_contract_id_from_fixtures(provider, logical_event)
  return "" unless blocking_capable_logical_event?(logical_event)
  return "" unless %w[claude codex].include?(provider)

  selected = StrictModeFixtureReadiness.selected_output_contracts(StrictModeMetadata.project_root, [provider])
  contract = selected.find do |candidate|
    candidate["provider"] == provider &&
      candidate["logical_event"] == logical_event &&
      candidate["contract_kind"] == "decision-output" &&
      candidate["contract_id"].is_a?(String) &&
      !candidate["contract_id"].empty?
  end
  contract ? contract.fetch("contract_id") : ""
rescue RuntimeError, ArgumentError, KeyError
  ""
end

def selected_output_contract(context, entry)
  return nil unless entry

  context.fetch("baseline").fetch("selected_output_contracts", []).find do |contract|
    contract.is_a?(Hash) &&
      contract["provider"] == entry.fetch("provider") &&
      contract["logical_event"] == entry.fetch("logical_event") &&
      contract["contract_id"] == entry.fetch("output_contract_id")
  end
end

def provider_output_metadata(contract)
  provider = contract.fetch("provider")
  root = StrictModeMetadata.project_root
  manifest_errors = StrictModeFixtures.validate_provider_manifest(root, provider)
  raise manifest_errors.join("\n") unless manifest_errors.empty?

  manifest = StrictModeFixtures.load_json(StrictModeFixtures.manifest_path(root, provider))
  record = manifest.fetch("records").find do |candidate|
    candidate["provider"] == provider &&
      candidate["event"] == contract.fetch("event") &&
      candidate["contract_kind"] == "decision-output" &&
      candidate["contract_id"] == contract.fetch("contract_id")
  end
  raise "selected output fixture record missing for #{provider} #{contract.fetch("logical_event")} #{contract.fetch("contract_id")}" unless record
  raise "selected output fixture manifest hash mismatch" unless manifest.fetch("manifest_hash") == contract.fetch("fixture_manifest_hash")
  raise "selected output fixture record hash mismatch" unless record.fetch("fixture_record_hash") == contract.fetch("fixture_record_hash")
  raise "selected output decision contract hash mismatch" unless record.fetch("decision_contract_hash") == contract.fetch("decision_contract_hash")

  metadata = StrictModeFixtureReadiness.decision_output_metadata(root, record)
  raise "selected output provider metadata missing or invalid" unless metadata
  raise "selected output provider action mismatch" unless metadata.fetch("provider_action") == contract.fetch("provider_action")

  metadata
end

def provider_output_metadata_from_contract_id(provider, logical_event, contract_id)
  root = StrictModeMetadata.project_root
  manifest_errors = StrictModeFixtures.validate_provider_manifest(root, provider)
  raise manifest_errors.join("\n") unless manifest_errors.empty?

  manifest = StrictModeFixtures.load_json(StrictModeFixtures.manifest_path(root, provider))
  record = manifest.fetch("records").find do |candidate|
    candidate["provider"] == provider &&
      candidate["event"] == logical_event &&
      candidate["contract_kind"] == "decision-output" &&
      candidate["contract_id"] == contract_id
  end
  raise "selected output fixture record missing for #{provider} #{logical_event} #{contract_id}" unless record

  metadata = StrictModeFixtureReadiness.decision_output_metadata(root, record)
  raise "selected output provider metadata missing or invalid" unless metadata
  metadata
end

def fail_closed_decision(logical_event, reason_code, message)
  {
    "schema_version" => 1,
    "action" => "block",
    "reason" => message,
    "severity" => "critical",
    "additional_context" => "",
    "metadata" => {
      "logical_event" => logical_event,
      "reason_code" => reason_code
    }
  }
end

JUDGE_RESPONSE_FIELDS = %w[
  backend
  confidence
  findings
  model
  reason
  response_hash
  reviewed_artifact_hash
  reviewed_scope_digest
  schema_version
  verdict
].freeze

def first_payload_string(payload, *keys)
  return "" unless payload.is_a?(Hash)

  keys.each do |key|
    value = payload[key]
    return value if value.is_a?(String) && !value.empty?
  end
  ""
end

def semantic_judge_history(payload)
  return [] unless payload.is_a?(Hash)

  value = payload["strict_judge_history"] || payload["judge_history"] || payload["fdr_history"]
  value.is_a?(Array) ? JSON.parse(JSON.generate(value)) : []
end

def normalized_assistant_text(normalized_event)
  turn = normalized_event.fetch("turn") if normalized_event.is_a?(Hash)
  return "" unless turn.is_a?(Hash)

  value = turn.fetch("assistant_text", "")
  value.is_a?(String) ? value : ""
end

def semantic_judge_input(payload, normalized_event)
  current_response = normalized_assistant_text(normalized_event)
  return nil if current_response.strip.empty?

  input = {
    "history" => semantic_judge_history(payload),
    "current_response" => current_response
  }
  last_user_msg = first_payload_string(payload, "last_user_msg", "last_user_message", "user_prompt", "prompt")
  input["last_user_msg"] = last_user_msg unless last_user_msg.empty?
  input["review_mode"] = payload["review_mode"] if payload.is_a?(Hash) && payload.key?("review_mode")
  input
end

def strict_judge_path
  program = Pathname.new($PROGRAM_NAME).expand_path.cleanpath
  sibling = program.dirname.join("strict-judge")
  return sibling if sibling.file?

  StrictModeMetadata.project_root.join("bin/strict-judge")
end

def parse_strict_judge_response(stdout, provider)
  record = JSON.parse(stdout, object_class: StrictModeMetadata::DuplicateKeyHash)
  raise "judge response root must be an object" unless record.is_a?(Hash)

  record = JSON.parse(JSON.generate(record))
  raise "judge response fields must be exact" unless record.keys.sort == JUDGE_RESPONSE_FIELDS.sort
  raise "judge schema_version invalid" unless record.fetch("schema_version") == 1
  raise "judge backend mismatch" unless record.fetch("backend") == provider
  raise "judge response hash mismatch" unless record.fetch("response_hash") == StrictModeMetadata.hash_record(record, "response_hash")
  raise "judge verdict invalid" unless %w[clean challenge unknown].include?(record.fetch("verdict"))
  raise "judge reason invalid" unless %w[clean challenge judge-disabled judge-invocation-unverified judge-state-isolation-failed-until-repair timeout nonzero-exit invalid-output empty-output parse-failure].include?(record.fetch("reason"))
  raise "judge findings must be an array" unless record.fetch("findings").is_a?(Array)
  record.fetch("findings").each do |finding|
    raise "judge finding fields must be exact" unless finding.is_a?(Hash) && finding.keys.sort == %w[message severity source]
    raise "judge finding severity invalid" unless %w[critical high medium low info].include?(finding.fetch("severity"))
    raise "judge finding source invalid" unless %w[artifact assistant-text scope-metadata].include?(finding.fetch("source"))
    raise "judge finding message invalid" unless finding.fetch("message").is_a?(String) && !finding.fetch("message").empty?
  end
  raise "judge challenge requires findings" if record.fetch("verdict") == "challenge" && record.fetch("findings").empty?
  raise "judge non-challenge findings must be empty" if record.fetch("verdict") != "challenge" && !record.fetch("findings").empty?

  record
rescue JSON::ParserError, KeyError, RuntimeError => e
  raise "invalid judge response: #{e.message}"
end

def bounded_reason(text, limit = 4000)
  value = text.to_s.strip
  return value if value.bytesize <= limit

  truncated = +""
  value.each_char do |char|
    break if truncated.bytesize + char.bytesize > limit

    truncated << char
  end
  "#{truncated}..."
end

def judge_block_decision(logical_event, response, fdr_cycle_record_hash = nil)
  messages = response.fetch("findings").map { |finding| finding.fetch("message", "").to_s.strip }.reject(&:empty?)
  messages = ["semantic judge reported a challenge"] if messages.empty?
  metadata = {
    "logical_event" => logical_event,
    "reason_code" => "judge-challenge",
    "response_hash" => response.fetch("response_hash")
  }
  metadata["fdr_cycle_record_hash"] = fdr_cycle_record_hash if fdr_cycle_record_hash
  {
    "schema_version" => 1,
    "action" => "block",
    "reason" => bounded_reason("strict-mode FDR judge challenge: #{messages.join("; ")}"),
    "severity" => "error",
    "additional_context" => "",
    "metadata" => metadata
  }
end

def judge_reuse_block_decision(logical_event, original_record)
  {
    "schema_version" => 1,
    "action" => "block",
    "reason" => bounded_reason("strict-mode FDR judge challenge: reused blocking challenge #{original_record.fetch("record_hash")}"),
    "severity" => "error",
    "additional_context" => "",
    "metadata" => {
      "logical_event" => logical_event,
      "reason_code" => "judge-challenge-reused",
      "response_hash" => original_record.fetch("response_hash"),
      "fdr_cycle_record_hash" => original_record.fetch("record_hash")
    }
  }
end

def judge_summary(attempted:, response: nil, reason: "", verdict: nil, backend: "", model: "", response_hash: nil, finding_count: nil)
  summary = {
    "attempted" => attempted,
    "verdict" => response ? response.fetch("verdict") : (verdict || "not-run"),
    "reason" => response ? response.fetch("reason") : reason,
    "backend" => response ? response.fetch("backend") : backend,
    "model" => response ? response.fetch("model") : model,
    "response_hash" => response ? response.fetch("response_hash") : (response_hash || ("0" * 64)),
    "finding_count" => response ? response.fetch("findings").length : (finding_count || 0)
  }
  summary["reason"] = reason if response.nil? && !reason.empty?
  summary
end

def attach_judge_summary(record, judge)
  return record unless judge

  record.merge("judge" => judge.reject { |key, _| key == "decision" })
end

def attach_record_edit_summary(record, record_edit)
  return record unless record_edit

  record.merge("record_edit" => record_edit.reject { |key, _| key == "message" })
end

def attach_fdr_cycle_summary(summary, cycle_record)
  return summary unless cycle_record

  summary.merge(
    "fdr_cycle_record_hash" => cycle_record.fetch("record_hash", ""),
    "fdr_cycle_ledger_record_hash" => cycle_record.fetch("ledger_record_hash", "")
  )
end

def append_fdr_cycle_safely(state_root, context, **kwargs)
  StrictModeFdrCycle.append_cycle!(state_root, context, **kwargs)
rescue RuntimeError, SystemCallError, ArgumentError => e
  warn "strict-hook FDR cycle append failed: #{e.message}"
  nil
end

def judge_prompt_template_hash(context)
  records = context.fetch("config_results", {}).fetch("judge-prompt-template.md", { "records" => [] }).fetch("records")
  content = records.map { |record| record.fetch("content", "").to_s }.join
  content.empty? ? StrictModeFdrCycle::ZERO_HASH : Digest::SHA256.hexdigest(content)
rescue KeyError, NoMethodError
  StrictModeFdrCycle::ZERO_HASH
end

def normalized_stop_event(provider, logical_event, payload, payload_hash: nil)
  return nil unless payload.is_a?(Hash)

  cwd = hook_cwd
  project_dir = hook_project_dir(cwd)
  StrictModeNormalized.normalize(
    payload,
    provider: provider,
    logical_event: logical_event,
    cwd: cwd,
    project_dir: project_dir,
    payload_sha256: payload_hash
  )
rescue RuntimeError, ArgumentError, KeyError
  nil
end

def semantic_judge_result(provider, logical_event, payload, state_root, prompt_template_hash: StrictModeFdrCycle::ZERO_HASH, payload_hash: nil)
  return judge_summary(attempted: false, reason: "not-stop-like") unless stop_continuation_logical_event?(logical_event)

  cwd = hook_cwd
  project_dir = hook_project_dir(cwd)
  normalized_event = normalized_stop_event(provider, logical_event, payload, payload_hash: payload_hash)
  cycle_context = if payload.is_a?(Hash)
                    StrictModeFdrCycle.context(provider: provider, payload: payload, cwd: cwd, project_dir: project_dir, normalized_event: normalized_event, require_normalized_assistant: true)
                  end
  input = semantic_judge_input(payload, normalized_event)
  unless input
    cycle_record = append_fdr_cycle_safely(
      state_root,
      cycle_context,
      decision: "skipped-no-turn-text",
      challenge_reason: "no-normalized-turn-text"
    ) if cycle_context
    return attach_fdr_cycle_summary(judge_summary(attempted: false, reason: "empty-current-response"), cycle_record)
  end

  if cycle_context
    reusable = StrictModeFdrCycle.reusable_result(state_root, cycle_context, prompt_template_hash: prompt_template_hash)
    if reusable && reusable.fetch("decision") == "judge-clean"
      return judge_summary(
        attempted: false,
        verdict: "clean",
        reason: "judge-clean-reused",
        backend: reusable.fetch("record").fetch("judge_backend"),
        model: reusable.fetch("record").fetch("judge_model"),
        response_hash: reusable.fetch("record").fetch("response_hash")
      ).merge("reused" => true, "fdr_cycle_record_hash" => reusable.fetch("record").fetch("record_hash"))
    elsif reusable && reusable.fetch("decision") == "judge-challenge"
      original = reusable.fetch("record")
      cycle_record = append_fdr_cycle_safely(
        state_root,
        cycle_context,
        decision: "blocked-reused",
        challenge_reason: "reused-blocking-challenge",
        original_challenge_record_hash: original.fetch("record_hash")
      )
      summary = judge_summary(
        attempted: false,
        verdict: "challenge",
        reason: "blocked-reused",
        backend: original.fetch("judge_backend"),
        model: original.fetch("judge_model"),
        response_hash: original.fetch("response_hash")
      ).merge("reused" => true, "decision" => judge_reuse_block_decision(logical_event, original))
      return attach_fdr_cycle_summary(summary, cycle_record)
    end
  end

  stdout, stderr, status = Open3.capture3(
    { "STRICT_MODE_NESTED" => "1" },
    RbConfig.ruby,
    strict_judge_path.to_s,
    "--provider", provider,
    "--reviewed-scope-digest", cycle_context ? cycle_context.fetch("scope_digest") : StrictModeFdrCycle::ZERO_HASH,
    "--reviewed-artifact-hash", cycle_context ? cycle_context.fetch("artifact_hash") : StrictModeFdrCycle::ZERO_HASH,
    "--install-root", inferred_install_root(state_root).to_s,
    "--state-root", state_root.to_s,
    "--project-dir", project_dir.to_s,
    stdin_data: JSON.generate(input)
  )
  unless status.success?
    failure_hash = cycle_context ? StrictModeFdrCycle.failure_response_hash(cycle_context, reason_code: "nonzero-exit", timed_out: false, exit_status: status.exitstatus, stdout: stdout, stderr: stderr) : StrictModeFdrCycle::ZERO_HASH
    cycle_record = append_fdr_cycle_safely(
      state_root,
      cycle_context,
      decision: "judge-unknown",
      challenge_reason: "nonzero-exit",
      prompt_hash: cycle_context ? StrictModeFdrCycle.prompt_hash(cycle_context, judge_backend: "", judge_model: "", prompt_template_hash: prompt_template_hash) : StrictModeFdrCycle::ZERO_HASH,
      response_hash: failure_hash
    ) if cycle_context
    return attach_fdr_cycle_summary(judge_summary(attempted: true, reason: "nonzero-exit", verdict: "unknown", response_hash: failure_hash), cycle_record)
  end

  begin
    response = parse_strict_judge_response(stdout, provider)
    if cycle_context
      raise "invalid judge response: reviewed_scope_digest mismatch" unless response.fetch("reviewed_scope_digest") == cycle_context.fetch("scope_digest")
      raise "invalid judge response: reviewed_artifact_hash mismatch" unless response.fetch("reviewed_artifact_hash") == cycle_context.fetch("artifact_hash")
    end
  rescue RuntimeError => e
    failure_hash = cycle_context ? StrictModeFdrCycle.failure_response_hash(cycle_context, reason_code: "parse-failure", timed_out: false, exit_status: status.exitstatus, stdout: stdout, stderr: stderr) : StrictModeFdrCycle::ZERO_HASH
    cycle_record = append_fdr_cycle_safely(
      state_root,
      cycle_context,
      decision: "judge-unknown",
      challenge_reason: "parse-failure",
      prompt_hash: cycle_context ? StrictModeFdrCycle.prompt_hash(cycle_context, judge_backend: "", judge_model: "", prompt_template_hash: prompt_template_hash) : StrictModeFdrCycle::ZERO_HASH,
      response_hash: failure_hash
    ) if cycle_context
    return attach_fdr_cycle_summary(judge_summary(attempted: true, reason: "parse-failure", verdict: "unknown", response_hash: failure_hash), cycle_record)
  end

  prompt_hash = cycle_context ? StrictModeFdrCycle.prompt_hash(cycle_context, judge_backend: response.fetch("backend"), judge_model: response.fetch("model"), prompt_template_hash: prompt_template_hash) : StrictModeFdrCycle::ZERO_HASH
  cycle_record = if cycle_context
                   case response.fetch("verdict")
                   when "clean"
                     append_fdr_cycle_safely(
                       state_root,
                       cycle_context,
                       decision: "judge-clean",
                       challenge_reason: "judge-clean",
                       judge_backend: response.fetch("backend"),
                       judge_model: response.fetch("model"),
                       prompt_hash: prompt_hash,
                       response_hash: response.fetch("response_hash")
                     )
                   when "challenge"
                     append_fdr_cycle_safely(
                       state_root,
                       cycle_context,
                       decision: "judge-challenge",
                       challenge_reason: "judge-reported-challenge",
                       judge_backend: response.fetch("backend"),
                       judge_model: response.fetch("model"),
                       prompt_hash: prompt_hash,
                       response_hash: response.fetch("response_hash")
                     )
                   else
                     append_fdr_cycle_safely(
                       state_root,
                       cycle_context,
                       decision: "judge-unknown",
                       challenge_reason: response.fetch("reason"),
                       judge_backend: response.fetch("backend"),
                       judge_model: response.fetch("model"),
                       prompt_hash: prompt_hash,
                       response_hash: response.fetch("response_hash")
                     )
                   end
                 end
  summary = judge_summary(attempted: true, response: response)
  summary = attach_fdr_cycle_summary(summary, cycle_record)
  summary.merge("decision" => response.fetch("verdict") == "challenge" ? judge_block_decision(logical_event, response, cycle_record && cycle_record.fetch("record_hash")) : nil)
rescue RuntimeError, SystemCallError, ArgumentError => e
  judge_summary(attempted: true, reason: e.message)
end

def enforcement_result(context, provider, logical_event, preflight, stop_hook_active: false, parsed_payload: nil, state_root: nil, payload_hash: nil, approval_notice: nil, override_decision: nil, provider_detection_decision: "unknown")
  entry = enforcing_hook_entry(context, provider, logical_event)
  if stop_hook_active && stop_continuation_logical_event?(logical_event) && enforcing_hook_invocation?
    contract_id = entry ? entry.fetch("output_contract_id") : ENV["STRICT_OUTPUT_CONTRACT_ID"].to_s
    contract_id = fallback_output_contract_id_from_fixtures(provider, logical_event) if contract_id.empty?
    unless contract_id.empty?
      return {
        "active" => true,
        "emitted" => false,
        "failed_closed" => false,
        "output_contract_id" => contract_id,
        "stop_hook_active" => true,
        "emission" => nil,
        "error" => ""
      }
    end
  end
  unless entry
    if !context.fetch("trusted", false) && blocking_capable_logical_event?(logical_event) && enforcing_hook_invocation?
      contract_id = ENV["STRICT_OUTPUT_CONTRACT_ID"].to_s
      contract_id = fallback_output_contract_id_from_fixtures(provider, logical_event) if contract_id.empty?
      message = "strict-mode protected context is untrusted: #{(context.fetch("errors") + context.fetch("config_errors")).join("; ")}"
      if contract_id.empty?
        return {
          "active" => true,
          "emitted" => true,
          "failed_closed" => true,
          "output_contract_id" => "",
          "stop_hook_active" => stop_hook_active,
          "emission" => { "stdout" => "", "stderr" => "strict-hook enforcement failed closed: #{message}\n", "exit_code" => 1 },
          "error" => message
        }
      end

      metadata = provider_output_metadata_from_contract_id(provider, logical_event, contract_id)
      decision = fail_closed_decision(logical_event, "protected-baseline-untrusted", message)
      emission = StrictModeDecisionContract.emit_provider_output(metadata, decision)
      return {
        "active" => true,
        "emitted" => true,
        "failed_closed" => true,
        "output_contract_id" => contract_id,
        "stop_hook_active" => stop_hook_active,
        "emission" => emission,
        "error" => message
      }
    end

    return { "active" => false, "emitted" => false, "failed_closed" => false, "output_contract_id" => "", "stop_hook_active" => stop_hook_active, "emission" => nil, "error" => "" }
  end

  unless context.fetch("trusted", false)
    metadata = provider_output_metadata_from_contract_id(provider, logical_event, entry.fetch("output_contract_id"))
    message = "strict-mode protected context is untrusted: #{(context.fetch("errors") + context.fetch("config_errors")).join("; ")}"
    decision = fail_closed_decision(logical_event, "protected-baseline-untrusted", message)
    emission = StrictModeDecisionContract.emit_provider_output(metadata, decision)
    return {
      "active" => true,
      "emitted" => true,
      "failed_closed" => true,
      "output_contract_id" => entry.fetch("output_contract_id"),
      "stop_hook_active" => stop_hook_active,
      "emission" => emission,
      "error" => message
    }
  end

  contract = selected_output_contract(context, entry)
  raise "selected output contract missing for #{provider} #{logical_event} #{entry.fetch("output_contract_id")}" unless contract

  record_edit = if stop_continuation_logical_event?(logical_event) && provider_detection_decision == "match"
                  StrictModeRecordEdit.stop_policy_from_payload(
                    state_root: state_root || inferred_install_root.join("state"),
                    provider: provider,
                    logical_event: logical_event,
                    payload: parsed_payload,
                    payload_hash: payload_hash,
                    cwd: hook_cwd,
                    project_dir: hook_project_dir(hook_cwd)
                  )
                end
  if record_edit && record_edit.fetch("decision") == "block"
    metadata = provider_output_metadata(contract)
    decision = fail_closed_decision(
      logical_event,
      record_edit.fetch("reason_code"),
      "strict-mode record edit blocked Stop: #{record_edit.fetch("message")}"
    )
    decision["metadata"]["record_edit_reason_code"] = record_edit.fetch("reason_code")
    decision["metadata"]["tool_intent_count"] = record_edit.fetch("tool_intent_count")
    decision["metadata"]["tool_count"] = record_edit.fetch("tool_count")
    decision["metadata"]["edit_count"] = record_edit.fetch("edit_count")
    emission = StrictModeDecisionContract.emit_provider_output(metadata, decision)
    return attach_record_edit_summary({
      "active" => true,
      "emitted" => true,
      "failed_closed" => true,
      "output_contract_id" => contract.fetch("contract_id"),
      "stop_hook_active" => stop_hook_active,
      "emission" => emission,
      "error" => record_edit.fetch("message")
    }, record_edit)
  end

  judge = stop_continuation_logical_event?(logical_event) ? semantic_judge_result(provider, logical_event, parsed_payload, state_root || inferred_install_root.join("state"), prompt_template_hash: judge_prompt_template_hash(context), payload_hash: payload_hash) : nil
  if judge && judge.fetch("verdict") == "clean"
    return attach_record_edit_summary(attach_judge_summary({ "active" => true, "emitted" => false, "failed_closed" => false, "output_contract_id" => contract.fetch("contract_id"), "stop_hook_active" => stop_hook_active, "emission" => nil, "error" => "" }, judge), record_edit)
  elsif judge && judge.fetch("verdict") == "challenge"
    metadata = provider_output_metadata(contract)
    emission = StrictModeDecisionContract.emit_provider_output(metadata, judge.fetch("decision"))
    return attach_record_edit_summary(attach_judge_summary({
      "active" => true,
      "emitted" => true,
      "failed_closed" => false,
      "output_contract_id" => contract.fetch("contract_id"),
      "stop_hook_active" => stop_hook_active,
      "emission" => emission,
      "error" => ""
    }, judge), record_edit)
  end

  decision = override_decision || StrictModeInternalDecision.from_preflight(preflight, stop_hook_active: stop_hook_active)
  if approval_notice && decision.fetch("action") == "block"
    phrase = approval_notice.fetch("phrase")
    decision["reason"] = bounded_reason("#{decision.fetch("reason")}\nAsk the user to reply with this exact line before retrying: #{phrase}")
    decision["additional_context"] = "strict-mode destructive confirmation required: #{phrase}"
    decision["metadata"]["approval_hash"] = approval_notice.fetch("approval_hash")
    decision["metadata"]["pending_record_hash"] = approval_notice.fetch("pending_record_hash")
    decision["metadata"]["next_marker"] = approval_notice.fetch("next_user_prompt_marker")
  end
  return attach_record_edit_summary(attach_judge_summary({ "active" => true, "emitted" => false, "failed_closed" => false, "output_contract_id" => contract.fetch("contract_id"), "stop_hook_active" => stop_hook_active, "emission" => nil, "error" => "" }, judge), record_edit) unless decision.fetch("action") == "block"

  metadata = provider_output_metadata(contract)
  emission = StrictModeDecisionContract.emit_provider_output(metadata, decision)
  attach_record_edit_summary(attach_judge_summary({
    "active" => true,
    "emitted" => true,
    "failed_closed" => false,
    "output_contract_id" => contract.fetch("contract_id"),
    "stop_hook_active" => stop_hook_active,
    "emission" => emission,
    "error" => ""
  }, judge), record_edit)
rescue RuntimeError, ArgumentError, KeyError => e
  {
    "active" => !!entry,
    "emitted" => false,
    "failed_closed" => true,
    "output_contract_id" => entry ? entry.fetch("output_contract_id", "") : "",
    "stop_hook_active" => stop_hook_active,
    "emission" => { "stdout" => "", "stderr" => "strict-hook enforcement failed closed: #{e.message}\n", "exit_code" => 1 },
    "error" => e.message
  }
end

payload_cap = 65_536
payload = STDIN.read(payload_cap + 1) || ""
payload_truncated = payload.bytesize > payload_cap
payload = payload.byteslice(0, payload_cap) if payload_truncated
payload_hash = Digest::SHA256.hexdigest(payload)
state_root = if ENV["STRICT_STATE_ROOT"]
               Pathname.new(ENV["STRICT_STATE_ROOT"]).expand_path.cleanpath
             else
               inferred_install_root.join("state")
             end
log_dir = state_root.join("discovery")
event_component = safe_component(event)
raw_payload_path = ""
raw_payload_captured = false
provider_proof = nil
provider_detection_error = ""
parsed_payload = nil

begin
  parsed_payload = JSON.parse(payload, object_class: StrictModeFixtures::DuplicateKeyHash)
  if parsed_payload.is_a?(Hash)
    provider_proof = StrictModeProviderDetection.proof(
      JSON.parse(JSON.generate(parsed_payload)),
      provider_arg: provider,
      provider_arg_source: provider_arg_source,
      payload_sha256: payload_hash
    )
    provider_errors = StrictModeProviderDetection.validate(provider_proof)
    raise provider_errors.join("; ") unless provider_errors.empty?
  else
    provider_detection_error = "payload JSON root is not an object"
  end
rescue JSON::ParserError
  provider_detection_error = "payload JSON parse failed"
rescue RuntimeError
  provider_detection_error = "provider proof validation failed"
end

provider_detection_decision = provider_proof ? provider_proof.fetch("decision") : "unknown"
provider_detection_diagnostic = if provider_proof
                                  provider_proof.fetch("diagnostic")
                                else
                                  "provider #{provider} could not be proven from payload: #{provider_detection_error}"
                                end
detected_provider = provider_proof ? provider_proof.fetch("detected_provider") : "unknown"
provider_proof_hash = provider_proof ? provider_proof.fetch("provider_proof_hash") : ("0" * 64)
warn "strict-hook provider mismatch: #{provider_detection_diagnostic}" if %w[mismatch conflict].include?(provider_detection_decision)
warn "strict-hook provider unknown: #{provider_detection_diagnostic}" if provider_detection_decision == "unknown"
logical_event = StrictModeNormalized.native_logical_event(event)
logical_event = "unknown" if logical_event.empty?

preflight = if provider_detection_decision == "match" && !payload_truncated
              classify_preflight(
                payload: parsed_payload,
                provider: provider,
                logical_event: logical_event,
                payload_hash: payload_hash,
                state_root: state_root
              )
            elsif logical_event == "pre-tool-use"
              preflight_error(
                logical_event,
                provider_detection_decision == "match" ? "payload-truncated" : "provider-untrusted",
                [provider_detection_diagnostic]
              )
            else
              preflight_not_attempted(logical_event)
            end
preflight = validate_preflight_or_error(logical_event, preflight)
context = protected_context(state_root)
trusted_state_written = false
approval_summary = nil
permission_summary = nil
permission_override_decision = nil
tool_intent_summary = nil
post_tool_summary = nil
turn_baseline_summary = nil
if logical_event == "pre-tool-use" &&
   preflight.fetch("attempted") &&
   preflight.fetch("trusted") &&
   preflight.fetch("decision") == "allow" &&
   preflight.fetch("reason_code") != "trusted-import-ready" &&
   provider_detection_decision == "match" &&
   !payload_truncated &&
   parsed_payload.is_a?(Hash) &&
   context.fetch("trusted", false) &&
   enforcing_hook_invocation? &&
   enforcing_hook_entry(context, provider, logical_event)
  begin
    cwd = hook_cwd
    intent = StrictModeRecordEdit.append_pre_tool_intent_from_payload!(
      state_root: state_root,
      provider: provider,
      payload: parsed_payload,
      payload_hash: payload_hash,
      cwd: cwd,
      project_dir: hook_project_dir(cwd)
    )
    if intent
      trusted_state_written = true
      tool_intent_summary = {
        "recorded" => true,
        "seq" => intent.fetch("seq"),
        "intent_hash" => intent.fetch("intent_hash"),
        "tool_kind" => intent.fetch("tool_kind"),
        "write_intent" => intent.fetch("write_intent")
      }
    else
      tool_intent_summary = { "recorded" => false, "reason" => "not-required" }
    end
  rescue RuntimeError, SystemCallError, ArgumentError, KeyError => e
    preflight = validate_preflight_or_error(
      logical_event,
      preflight_error(logical_event, "preflight-error", ["tool intent append failed: #{e.message}"])
    )
    tool_intent_summary = { "recorded" => false, "reason" => "record-failure", "error" => e.message }
  end
end
if logical_event == "permission-request" &&
   provider_detection_decision == "match" &&
   !payload_truncated &&
   parsed_payload.is_a?(Hash) &&
   context.fetch("trusted", false) &&
   enforcing_hook_invocation? &&
   enforcing_hook_entry(context, provider, logical_event)
  begin
    cwd = hook_cwd
    permission_record = StrictModePermissionDecision.append_decision_from_payload!(
      state_root: state_root,
      provider: provider,
      payload: parsed_payload,
      payload_hash: payload_hash,
      cwd: cwd,
      project_dir: hook_project_dir(cwd),
      baseline: context
    )
    permission_override_decision = StrictModePermissionDecision.internal_decision(permission_record)
    permission_summary = {
      "recorded" => true,
      "decision" => permission_record.fetch("decision"),
      "reason_code" => permission_record.fetch("reason_code"),
      "record_hash" => permission_record.fetch("record_hash")
    }
    trusted_state_written = true
  rescue RuntimeError, SystemCallError, ArgumentError, KeyError => e
    permission_override_decision = StrictModePermissionDecision.record_failure_decision(e.message)
    permission_summary = {
      "recorded" => false,
      "decision" => "deny",
      "reason_code" => "deny-record-failure",
      "error" => e.message
    }
  end
end
if logical_event == "post-tool-use" &&
   provider_arg_source == "argv" &&
   provider_detection_decision == "match" &&
   !payload_truncated &&
   parsed_payload.is_a?(Hash) &&
   context.fetch("trusted", false)
  begin
    cwd = hook_cwd
    post_tool_summary = StrictModeRecordEdit.append_post_tool_records_from_payload!(
      state_root: state_root,
      provider: provider,
      payload: parsed_payload,
      payload_hash: payload_hash,
      cwd: cwd,
      project_dir: hook_project_dir(cwd)
    )
    trusted_state_written = true
  rescue RuntimeError, SystemCallError, ArgumentError, KeyError => e
    warn "strict-hook post-tool record failed: #{e.message}"
    post_tool_summary = { "recorded" => false, "error" => e.message }
  end
end
if logical_event == "user-prompt-submit" &&
   provider_detection_decision == "match" &&
   !payload_truncated &&
   parsed_payload.is_a?(Hash) &&
   context.fetch("trusted", false)
  begin
    cwd = hook_cwd
    approval_summary = StrictModeApprovalState.record_user_prompt!(
      state_root: state_root,
      install_root: inferred_install_root(state_root),
      provider: provider,
      payload: parsed_payload,
      payload_hash: payload_hash,
      cwd: cwd,
      project_dir: hook_project_dir(cwd)
    )
    trusted_state_written = true
  rescue RuntimeError, SystemCallError, ArgumentError, KeyError => e
    warn "strict-hook approval prompt handling failed: #{e.message}"
    approval_summary = { "error" => e.message }
  end
end
if logical_event == "user-prompt-submit" &&
   provider_detection_decision == "match" &&
   !payload_truncated &&
   parsed_payload.is_a?(Hash) &&
   context.fetch("trusted", false)
  begin
    cwd = hook_cwd
    baseline = StrictModeRecordEdit.write_turn_baseline_from_payload!(
      state_root: state_root,
      provider: provider,
      payload: parsed_payload,
      payload_hash: payload_hash,
      cwd: cwd,
      project_dir: hook_project_dir(cwd),
      prompt_seq: approval_summary.is_a?(Hash) ? approval_summary.fetch("prompt_seq", 0) : 0
    )
    if baseline
      trusted_state_written = true
      turn_baseline_summary = {
        "recorded" => true,
        "baseline_hash" => baseline.fetch("baseline_hash"),
        "prompt_seq" => baseline.fetch("prompt_seq"),
        "last_sequences" => baseline.fetch("last_sequences"),
        "last_safe_stop_sequences" => baseline.fetch("last_safe_stop_sequences")
      }
    end
  rescue RuntimeError, SystemCallError, ArgumentError, KeyError => e
    warn "strict-hook turn baseline handling failed: #{e.message}"
    turn_baseline_summary = { "recorded" => false, "error" => e.message }
  end
end
approval_notice = nil
if preflight.fetch("attempted") &&
   preflight.fetch("trusted") &&
   preflight.fetch("decision") == "block" &&
   preflight.fetch("reason_code") == "destructive-command" &&
   provider_detection_decision == "match" &&
   !payload_truncated &&
   parsed_payload.is_a?(Hash) &&
   context.fetch("trusted", false) &&
   enforcing_hook_invocation? &&
   enforcing_hook_entry(context, provider, logical_event)
  begin
    cwd = hook_cwd
    consumed = StrictModeApprovalState.consume_destructive_confirmation!(
      state_root: state_root,
      install_root: inferred_install_root(state_root),
      provider: provider,
      payload: parsed_payload,
      payload_hash: payload_hash,
      preflight: preflight,
      cwd: cwd,
      project_dir: hook_project_dir(cwd),
      min_age_sec: protected_runtime_settings(state_root).fetch("STRICT_CONFIRM_MIN_AGE_SEC", "0").to_i
    )
    if consumed.fetch("consumed")
      approval_summary = consumed
      trusted_state_written = true
      preflight = validate_preflight_or_error(
        logical_event,
        StrictModePreflightRecord.trusted_allow_from_preflight(
          preflight,
          "destructive-confirmed",
          "strict-mode destructive command confirmed by user approval #{consumed.fetch("approval_hash")}"
        )
      )
    end
  rescue RuntimeError, SystemCallError, ArgumentError, KeyError => e
    preflight = validate_preflight_or_error(
      logical_event,
      preflight_error(logical_event, "preflight-error", ["destructive confirmation consume failed: #{e.message}"])
    )
    approval_summary = { "error" => e.message }
  end
end
if preflight.fetch("attempted") &&
   preflight.fetch("trusted") &&
   preflight.fetch("decision") == "allow" &&
   preflight.fetch("reason_code") == "trusted-import-ready" &&
   provider_detection_decision == "match" &&
   !payload_truncated &&
   parsed_payload.is_a?(Hash) &&
   context.fetch("trusted", false) &&
   enforcing_hook_invocation? &&
   enforcing_hook_entry(context, provider, logical_event)
  begin
    cwd = hook_cwd
    intent = StrictModeFdrImport.append_import_intent_from_payload!(
      state_root: state_root,
      install_root: inferred_install_root(state_root),
      provider: provider,
      logical_event: logical_event,
      payload: parsed_payload,
      payload_hash: payload_hash,
      cwd: cwd,
      project_dir: hook_project_dir(cwd)
    )
    trusted_state_written = !intent.nil?
    preflight = validate_preflight_or_error(logical_event, preflight_error(logical_event, "preflight-error", ["trusted import intent was not written"])) unless trusted_state_written
  rescue RuntimeError, SystemCallError, ArgumentError, KeyError => e
    preflight = validate_preflight_or_error(logical_event, preflight_error(logical_event, "preflight-error", ["trusted import intent append failed: #{e.message}"]))
  end
end
if preflight.fetch("attempted") &&
   preflight.fetch("trusted") &&
   preflight.fetch("decision") == "block" &&
   preflight.fetch("reason_code") == "destructive-command" &&
   provider_detection_decision == "match" &&
   !payload_truncated &&
   parsed_payload.is_a?(Hash) &&
   context.fetch("trusted", false) &&
   enforcing_hook_invocation? &&
   enforcing_hook_entry(context, provider, logical_event)
  begin
    cwd = hook_cwd
    approval_notice = StrictModeApprovalState.note_destructive_block!(
      state_root: state_root,
      install_root: inferred_install_root(state_root),
      provider: provider,
      payload: parsed_payload,
      payload_hash: payload_hash,
      preflight: preflight,
      cwd: cwd,
      project_dir: hook_project_dir(cwd)
    )
    approval_summary = approval_notice if approval_notice
    trusted_state_written ||= !approval_notice.nil?
  rescue RuntimeError, SystemCallError, ArgumentError, KeyError => e
    warn "strict-hook approval pending write failed: #{e.message}"
    approval_summary = { "error" => e.message }
  end
end
stop_hook_active = provider_detection_decision == "match" &&
                   !payload_truncated &&
                   parsed_payload.is_a?(Hash) &&
                   stop_continuation_logical_event?(logical_event) &&
                   parsed_payload["stop_hook_active"] == true
enforcement = enforcement_result(
  context,
  provider,
  logical_event,
  preflight,
  stop_hook_active: stop_hook_active,
  parsed_payload: parsed_payload,
  state_root: state_root,
  payload_hash: payload_hash,
  approval_notice: approval_notice,
  override_decision: permission_override_decision,
  provider_detection_decision: provider_detection_decision
)
if preflight.fetch("would_block") && !enforcement.fetch("active")
  warn "strict-hook preflight would block in enforcement: #{preflight.fetch("reason_code")} (discovery log-only)"
end

runtime_settings = if enforcement.fetch("failed_closed") || (enforcement.fetch("active") && enforcement.fetch("stop_hook_active", false))
                     {}
                   else
                     protected_runtime_settings(state_root)
                   end
if runtime_settings["STRICT_CAPTURE_RAW_PAYLOADS"] == "1" && !payload_truncated && %w[claude codex].include?(provider) && provider_detection_decision == "match"
  begin
    raw_dir = log_dir.join("raw", provider, event_component)
    FileUtils.mkdir_p(raw_dir, mode: 0o700)
    raw_payload_path = raw_dir.join("#{Time.now.utc.strftime("%Y%m%dT%H%M%S")}-#{$$}-#{SecureRandom.hex(4)}-#{payload_hash[0, 12]}.payload").to_s
    File.open(raw_payload_path, File::WRONLY | File::CREAT | File::EXCL, 0o600) { |file| file.write(payload) }
    raw_payload_captured = true
  rescue SystemCallError, RuntimeError => e
    raw_payload_path = ""
    warn "strict-hook raw payload capture failed: #{e.message}"
  end
end

record = {
  "schema_version" => 1,
  "recorded_at" => Time.now.utc.iso8601,
  "provider" => provider,
  "event" => event,
  "mode" => enforcement.fetch("active") ? "enforcing" : "discovery-log-only",
  "provider_arg_source" => provider_arg_source,
  "detected_provider" => detected_provider,
  "provider_detection_decision" => provider_detection_decision,
  "provider_detection_diagnostic" => provider_detection_diagnostic,
  "provider_proof_hash" => provider_proof_hash,
  "payload_bytes" => payload.bytesize,
  "payload_truncated" => payload_truncated,
  "payload_sha256" => payload_hash,
  "raw_payload_captured" => raw_payload_captured,
  "raw_payload_path" => raw_payload_path,
  "preflight" => preflight,
  "enforcement" => enforcement.reject { |key, _value| key == "emission" },
  "trusted_state_written" => trusted_state_written
}
record["approval"] = approval_summary if approval_summary
record["permission_decision"] = permission_summary if permission_summary
record["tool_intent"] = tool_intent_summary if tool_intent_summary
record["post_tool_record"] = post_tool_summary if post_tool_summary
record["turn_baseline"] = turn_baseline_summary if turn_baseline_summary

begin
  FileUtils.mkdir_p(log_dir, mode: 0o700)
  path = log_dir.join("#{provider}-#{event_component}.jsonl")
  File.open(path, "a", 0o600) { |file| file.puts(JSON.generate(record)) }
rescue SystemCallError, RuntimeError => e
  warn "strict-hook discovery log failed: #{e.message}"
end

if enforcement.fetch("emitted") || enforcement.fetch("failed_closed")
  emission = enforcement.fetch("emission")
  STDOUT.write(emission.fetch("stdout"))
  STDERR.write(emission.fetch("stderr"))
  exit emission.fetch("exit_code")
end

# UserPromptSubmit prompt injection: при доверенной baseline и непустом контенте
# в `<config-root>/user-prompt-injection.md` пишем содержимое в stdout один
# раз на provider session — provider добавляет stdout к user prompt'у per
# UserPromptSubmit hook contract.
# Recursion guard STRICT_MODE_NESTED=1 пропускает injection (nested `claude -p`
# вызовы не должны получать ту же rules-вставку повторно).
if logical_event == "user-prompt-submit" &&
   ENV["STRICT_MODE_NESTED"] != "1" &&
   context.fetch("trusted", false) &&
   should_emit_prompt_injection?(state_root, provider, parsed_payload)
  injection_records = context.fetch("config_results").fetch("user-prompt-injection.md", { "records" => [] }).fetch("records")
  injection_text = injection_records.map { |record| record.fetch("content", "").to_s }.join
  unless injection_text.empty?
    STDOUT.write(injection_text)
    STDOUT.write("\n") unless injection_text.end_with?("\n")
    exit 0
  end
end

exit 0
