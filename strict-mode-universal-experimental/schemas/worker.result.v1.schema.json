  "variant_requirements": [
    "patch output scoped",
    "findings output scoped",
    "clean result non-authoritative",
    "confidence decimal bounds"
  ],
  "variant_rules": {
    "patch output scoped": {
      "selectors": [
        "output_kind=patch or rewrite-suggestion"
      ],
      "requires": [
        "touched paths subset of context allowed_paths"
      ],
      "forbids": [
        "protected-root path",
        "out-of-scope path"
      ]
    },
    "findings output scoped": {
      "selectors": [
        "output_kind=findings"
      ],
      "requires": [
        "findings path in scope",
        "valid severity",
        "bounded harm and fix"
      ],
      "forbids": [
        "empty path",
        "empty harm",
        "empty fix"
      ]
    },
    "clean result non-authoritative": {
      "selectors": [
        "advisory_only=true"
      ],
      "requires": [
        "no allow, bypass, approval, clean FDR, or Stop decision fields"
      ],
      "forbids": [
        "authority claim"
      ]
    },
    "confidence decimal bounds": {
      "selectors": [
        "confidence present"
      ],
      "requires": [
        "decimal 0..1 up to 3 fractional digits"
      ],
      "forbids": [
        "out-of-range confidence"
      ]
    }
  },
